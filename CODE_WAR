      '<feDropShadow dx="0" dy="5" stdDeviation="6" flood-color="#000" flood-opacity=".55"/></filter>';
  svg.appendChild(defs);

  svg.appendChild(mk('rect',{width:1600,height:900,fill:'url(#ocean)'}));
  svg.appendChild(mk('rect',{width:1600,height:900,fill:'url(#grat)'}));

  gWorld = mk('g',{id:'world'});
  svg.appendChild(gWorld);

  // Carrega GeoJSON de países reais
  try {
    const response = await fetch('https://raw.githubusercontent.com/nvkelso/natural-earth-vector/master/geojson/ne_110m_admin_0_countries.geojson');
    const geoData = await response.json();
    
    // Agrupa países por território do WAR
    const territoryGeo = {};
    TERRS.forEach(t => territoryGeo[t.id] = []);
    
    for (const feature of geoData.features) {
      const iso = feature.properties.ISO_A3 || feature.properties.ISO_A2;
      const terrId = COUNTRY_TO_TERRITORY[iso];
      if (terrId && territoryGeo[terrId]) {
        territoryGeo[terrId].push(feature);
      }
    }
    
    // Renderiza territórios
    gTerr = mk('g',{id:'terrs'});
    TERRS.forEach(t=>{
      const g=mk('g',{class:'terr','data-id':t.id});
      const features = territoryGeo[t.id];
      
      if (features && features.length > 0) {
        // Combina todos os polígonos do território
        let combinedPath = '';
        for (const feature of features) {
          if (feature.geometry.type === 'Polygon') {
            combinedPath += geoJSONtoPath(feature.geometry.coordinates);
          } else if (feature.geometry.type === 'MultiPolygon') {
            for (const polygon of feature.geometry.coordinates) {
              combinedPath += geoJSONtoPath(polygon);
            }
          }
        }
        
        if (combinedPath) {
          g.appendChild(mk('path',{class:'tp',d:combinedPath,filter:'url(#soft)'}));
        }
      }
      
      // Calcula centroide
      const [cx, cy] = calculateCentroid(features || []);
      t.k = [cx, cy];
      
      const nm=mk('text',{class:'tn',x:cx,y:cy+30}); nm.textContent=t.n;
      g.appendChild(nm);
      const bg=mk('g',{class:'badge'});
      bg.appendChild(mk('circle',{cx:cx,cy:cy,r:16}));
      const tx=mk('text',{x:cx,y:cy}); tx.textContent='1';
      bg.appendChild(tx); g.appendChild(bg);
      gTerr.appendChild(g);
    });
    gWorld.appendChild(gTerr);
    
  } catch (error) {
    console.error('Erro ao carregar GeoJSON:', error);
    // Fallback para polígonos simples
    gTerr = mk('g',{id:'terrs'});
    TERRS.forEach(t => {
      const g = mk('g',{class:'terr','data-id':t.id});
      const cx = 800 + (Math.random() - 0.5) * 1400;
      const cy = 450 + (Math.random() - 0.5) * 700;
      t.k = [cx, cy];
      g.appendChild(mk('circle',{class:'tp',cx:cx,cy:cy,r:30}));
      g.appendChild(mk('text',{class:'tn',x:cx,y:cy+30})).textContent=t.n;
      gTerr.appendChild(g);
    });
    gWorld.appendChild(gTerr);
  }

  // Rotas de fronteira
  gLinks = mk('g',{id:'links'});
  const done=new Set();
  Object.keys(ADJ).forEach(a=>{
    if (!byId[a].k) return;
    ADJ[a].forEach(b=>{
      if (!byId[b].k) return;
      const key=[a,b].sort().join('|'); 
      if(done.has(key))return; 
      done.add(key);
      const [x1,y1]=byId[a].k,[x2,y2]=byId[b].k;
      gLinks.appendChild(mk('line',{x1:x1,y1:y1,x2:x2,y2:y2, class:'link'+(SEA.has(key)?' sea':'')}));
    });
  });
  gWorld.appendChild(gLinks);

  gFx = mk('g',{id:'fx'}); gWorld.appendChild(gFx);

  bindMap();
  applyView();
}

/* ---------- pan / zoom ---------- */
function applyView(){ gWorld.setAttribute('transform',`translate(${view.x} ${view.y}) scale(${view.k})`); }
function zoomAt(cx,cy,factor){
  const k2=clamp(view.k*factor,.7,3.4);
  const f=k2/view.k;
  view.x = cx-(cx-view.x)*f; view.y = cy-(cy-view.y)*f; view.k=k2;
  applyView();
}
function svgPt(ev){
  const r=svg.getBoundingClientRect();
  const x=( (ev.clientX-r.left)/r.width )*1600;
  const y=( (ev.clientY-r.top )/r.height)*900;
  return [x,y];
}
let mapBound=false;
function bindMap(){
  if(mapBound) return;
  mapBound=true;
  let drag=null, moved=0, downId=null;
  svg.addEventListener('wheel',e=>{e.preventDefault();const[cx,cy]=svgPt(e);zoomAt(cx,cy,e.deltaY<0?1.14:1/1.14);},{passive:false});
  svg.addEventListener('pointerdown',e=>{
    if(e.button!==0 && e.pointerType==='mouse') return;
    const g0=e.target.closest?.('.terr'); downId = g0 ? g0.dataset.id : null;
    drag={x:e.clientX,y:e.clientY,vx:view.x,vy:view.y}; moved=0; svg.classList.add('dragging'); svg.setPointerCapture(e.pointerId);
  });
  svg.addEventListener('pointermove',e=>{
    if(drag){
      const r=svg.getBoundingClientRect(), sx=1600/r.width, sy=900/r.height;
      const dx=(e.clientX-drag.x)*sx, dy=(e.clientY-drag.y)*sy;
      moved=Math.max(moved,Math.abs(dx)+Math.abs(dy));
      view.x=drag.vx+dx; view.y=drag.vy+dy; applyView();
    } else hoverTerr(e);
  });
  const up=e=>{
    if(drag){
      svg.classList.remove('dragging');
      if(moved<6 && downId){ const g=gTerr.querySelector(`[data-id="${downId}"]`); if(g) onTerrClick(downId); }
      drag=null; downId=null;
    }
  };
  svg.addEventListener('pointerup',up);
  svg.addEventListener('pointercancel',()=>{drag=null;downId=null;svg.classList.remove('dragging');});
  svg.addEventListener('pointerleave',()=>{ if(!drag) hideTip(); });
  svg.addEventListener('contextmenu',e=>{
    const g=e.target.closest?.('.terr'); if(!g) return;
    e.preventDefault();
    onTerrRightClick(g.dataset.id);
  });
  $('#zIn').onclick=()=>zoomAt(800,450,1.2);
  $('#zOut').onclick=()=>zoomAt(800,450,1/1.2);
  $('#zRst').onclick=()=>{view={k:1,x:0,y:0};applyView();};
}

/* ---------- tooltip ---------- */
const tip=$('#tooltip');
function hideTip(){ tip.classList.remove('on'); }
function hoverTerr(e){
  const g=e.target.closest?.('.terr');
  if(!g){ hideTip(); return; }
  const id=g.dataset.id, t=byId[id], st=S.terr[id], p=S.players[st.o];
  const wrap=$('#mapwrap').getBoundingClientRect();
  let extra='';
  if(S.settings.odds && S.sel && S.phase==='ataque' && ADJ[S.sel].includes(id) && st.o!==cur().i && cur()===me()){
    const pc=pConquer(armies(S.sel), st.a);
    extra = `<div class="r"><span>Chance de tomar</span><i>${(pc*100).toFixed(0)}%</i></div>`;
  }
  tip.innerHTML = `<b>${t.n}</b>
    <div class="r"><span>${CONTS[t.c].n}</span><i>${SYMS[t.s]}</i></div>
    <div class="r"><span>Ocupante</span><i style="color:${p.color.hex}">${p.name}</i></div>
    <div class="r"><span>Exércitos</span><i>${st.a}</i></div>
    <div class="r"><span>Fronteiras</span><i>${ADJ[id].length}</i></div>${extra}`;
  tip.classList.add('on');
  const x=e.clientX-wrap.left+14, y=e.clientY-wrap.top+14;
  tip.style.left=Math.min(x, wrap.width-tip.offsetWidth-8)+'px';
  tip.style.top=Math.min(y, wrap.height-tip.offsetHeight-8)+'px';
}

/* ---------- efeitos ---------- */
function ripple(id,color){
  const [x,y]=byId[id].k;
  const c=mk('circle',{cx:x,cy:y,r:8,class:'ripple',stroke:color});
  gFx.appendChild(c);
  const t0=performance.now();
  const step=t=>{ const u=Math.min(1,(t-t0)/620);
    c.setAttribute('r', 8+u*58); c.setAttribute('opacity', (1-u).toFixed(3));
    if(u<1) requestAnimationFrame(step); else c.remove(); };
  requestAnimationFrame(step);
}
function flash(id){ const g=gTerr.querySelector(`[data-id="${id}"] .tp`); if(!g) return;
  g.style.transition='none'; g.style.filter='brightness(2.1)';
  setTimeout(()=>{g.style.transition='';g.style.filter='';},130); }

/* ==================================================================
   11. RENDERIZAÇÃO
   ================================================================== */
function render(){
  const p=cur();
  // mapa
  TERRS.forEach(t=>{
    const g=gTerr.querySelector(`[data-id="${t.id}"]`);
    if (!g) return;
    const st=S.terr[t.id], own=S.players[st.o];
    const poly=g.querySelector('.tp'), circ=g.querySelector('.badge circle'), txt=g.querySelector('.badge text');
    if (poly) {
      poly.setAttribute('fill', own.color.hex);
      poly.setAttribute('fill-opacity', .88);
    }
    if (circ) circ.setAttribute('fill', shade(own.color.hex,-58));
    if (txt) {
      txt.setAttribute('fill', own.color.id==='branco'||own.color.id==='amarelo' ? '#f2efe6' : '#f4f1e6');
      txt.textContent = st.a;
    }
    const tn = g.querySelector('.tn');
    if (tn) tn.style.display = S.settings.names ? '' : 'none';
    g.classList.remove('sel','tgt','dim','pulse');
  });
  gLinks.style.display = S.settings.links ? '' : 'none';

  // destaques por fase
  if(!S.gameOver && p===me() && !S.busy){
    if(S.phase==='reforco'||S.phase==='inicial'){
      ownedBy(p).forEach(id=>{
        const g = gTerr.querySelector(`[data-id="${id}"]`);
        if (g) g.classList.add('pulse');
      });
    } else if(S.phase==='ataque'){
      if(S.sel){
        const g = gTerr.querySelector(`[data-id="${S.sel}"]`);
        if (g) g.classList.add('sel');
        const tg=enemiesOf(S.sel,p);
        TERRS.forEach(t=>{ 
          const g = gTerr.querySelector(`[data-id="${t.id}"]`);
          if (g) {
            if(t.id!==S.sel && !tg.includes(t.id)) g.classList.add('dim');
            else if(tg.includes(t.id)) g.classList.add('tgt');
          }
        });
      } else {
        ownedBy(p).filter(id=>armies(id)>1 && enemiesOf(id,p).length).forEach(id=>{
          const g = gTerr.querySelector(`[data-id="${id}"]`);
          if (g) g.classList.add('pulse');
        });
      }
    } else if(S.phase==='remanejar'){
      if(S.sel){
        const g = gTerr.querySelector(`[data-id="${S.sel}"]`);
        if (g) g.classList.add('sel');
        const tg=ADJ[S.sel].filter(id=>isMine(id,p));
        TERRS.forEach(t=>{ 
          const g = gTerr.querySelector(`[data-id="${t.id}"]`);
          if (g) {
            if(t.id!==S.sel && !tg.includes(t.id)) g.classList.add('dim');
            else if(tg.includes(t.id)) g.classList.add('pulse');
          }
        });
      } else {
        ownedBy(p).filter(id=>armies(id)>1 && !S.srcUsed.has(id) && !S.gotArmies.has(id) && ADJ[id].some(x=>isMine(x,p)))
          .forEach(id=>{
            const g = gTerr.querySelector(`[data-id="${id}"]`);
            if (g) g.classList.add('pulse');
          });
      }
    }
  }

  // topo
  $('#curDot').style.background=p.color.hex; $('#curDot').style.color=p.color.hex;
  $('#curName').textContent = p.isAI ? p.name : p.name+' (você)';
  $('#roundLbl').textContent='Rodada '+S.round;
  const stepPhase = S.phase==='inicial' ? 'reforco' : S.phase;
  $$('.phase').forEach(e=>e.classList.toggle('active', e.dataset.p===stepPhase && !S.gameOver));

  renderPlayers(); renderConts(); renderObjective(); renderHand(); renderPowers(); renderActions();
}

