let B=null;
function dieEl(v,def){
  const PIPS={1:[4],2:[0,8],3:[0,4,8],4:[0,2,6,8],5:[0,2,4,6,8],6:[0,2,3,5,6,8],7:[0,1,2,6,7,8]};
  const d=document.createElement('div'); d.className='die'+(def?' def':'');
  for(let i=0;i<9;i++){ const s=document.createElement('span'); if(PIPS[v].includes(i)) s.className='pip'; d.appendChild(s); }
  return d;
}
function openBattle(from,to){
  const a=cur(), d=S.players[S.terr[to].o];
  B={from,to,a,d};
  a._battleLossA=0; a._battleLossD=0;
  $('#battleSub').innerHTML=`<b style="color:${a.color.hex}">${a.name}</b> ataca <b style="color:${d.color.hex}">${d.name}</b>`;
  $('#blog').innerHTML='';
