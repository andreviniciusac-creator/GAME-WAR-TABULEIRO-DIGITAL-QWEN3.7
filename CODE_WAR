    tag.textContent = `Neste combate: atacante perdeu ${a._battleLossA||0} · defensor perdeu ${a._battleLossD||0}`;
  }
}
function battleMods(a,d){ return {extraDie: !!a.eff.artilharia, wall: !!d.eff.wall}; }

async function battleRound(){
  const {from,to,a,d}=B;
  if(armies(from)<2) return;
  S.busy=true; $('#btnRoll').disabled=true; $('#btnBlitz').disabled=true;
  const mods=battleMods(a,d);
  const r=resolveRound(armies(from),armies(to),mods);
  drawBattle(); const dA=$('#dA'), dD=$('#dD');
  const nA=Math.min(mods.extraDie?4:3,armies(from)-1), nD=Math.min(2,armies(to));
  for(let i=0;i<nA;i++){const e=dieEl(1+rnd(6),false);e.classList.add('rolling');dA.appendChild(e);}
  for(let i=0;i<nD;i++){const e=dieEl(1+rnd(6),true);e.classList.add('rolling');dD.appendChild(e);}
  sfx.dice(); await wait(520);
  a.eff.artilharia=false;
  S.terr[from].a-=r.aLoss; S.terr[to].a-=r.dLoss;
  a.battles++; a.lost+=r.aLoss; d.lost+=r.dLoss;
  a._battleLossA=(a._battleLossA||0)+r.aLoss; a._battleLossD=(a._battleLossD||0)+r.dLoss;
  drawBattle(r);
  if(r.dLoss) sfx.hit();
  const bl=$('#blog');
  bl.insertAdjacentHTML('afterbegin',
    `<div>🔴 ${r.aKept.join('  ')} <span style="color:var(--brass)">vs</span> 🟡 ${r.dEff.join('  ')} → ` +
    `<span class="${r.dLoss?'win':'lose'}">atacante ${r.aLoss?'-'+r.aLoss:'0'}</span> · ` +
    `<span class="${r.dLoss?'win':'lose'}">defensor ${r.dLoss?'-'+r.dLoss:'0'}</span></div>`);
  render();
  if(armies(to)===0){ await conquer(from,to,a,d,r); return true; }
  S.busy=false; $('#btnRoll').disabled=armies(from)<2; $('#btnBlitz').disabled=armies(from)<2;
  renderActions();
  return false;
}
function applyConquest(from,to,a,d,n){
  S.terr[from].a -= n;
  S.terr[to].a = n + (a.eff.blitz?1:0);
  if(ownedBy(d).length===0) eliminate(d,a);
}
async function conquer(from,to,a,d,r){
  ripple(to,a.color.hex); sfx.conq();
  const maxMove = Math.min(3, armies(from)-1);
  const dice = r ? r.aKept.length : 1;
  const minMove = clamp(Math.min(3,dice), 1, maxMove);
  S.terr[to].o = a.i; S.terr[to].a = 0;
  S.conquered++; a.conq++;
  log(a, `conquistou <em>${byId[to].n}</em> de ${d.name}.`);

  let n;
  if(a===me()){
    $('#mBattle').classList.remove('on');
    await sleep(140);
    n = maxMove>minMove
      ? await askMoveP('Ocupar território', `De ${byId[from].n} para ${byId[to].n} — mínimo ${minMove}, máximo ${maxMove}`, minMove, maxMove)
      : minMove;
  } else {
    n = clamp(Math.round((armies(from)-1)*.72), minMove, maxMove);
  }
  applyConquest(from,to,a,d,n);
  S.busy=false; S.sel=null; B=null;
  render();
  checkVictory();
  render();
  return true;
}
