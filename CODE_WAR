<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
<title>WAR — Estratégia e Conquista</title>
<style>
:root{
  --abyss:#05090f;--ink:#0b1322;--chart:#132039;--panel:rgba(12,20,34,.82);
  --line:rgba(200,155,60,.18);--line2:rgba(148,170,200,.14);--brass:#c89b3c;
  --brass-dim:#8a6c2c;--verdigris:#4e9c8b;--rust:#b5442e;--bone:#e6e2d3;
  --muted:#8fa0b8;--shadow:0 18px 50px -20px rgba(0,0,0,.9);
  --serif:"Iowan Old Style","Palatino Linotype",Palatino,"Book Antiqua",Georgia,serif;
  --sans:ui-sans-serif,system-ui,-apple-system,"Segoe UI",Roboto,"Helvetica Neue",Arial,sans-serif;
  --mono:ui-monospace,SFMono-Regular,"SF Mono",Menlo,Consolas,monospace;
}
*{box-sizing:border-box}html,body{height:100%}
body{margin:0;background:var(--abyss);color:var(--bone);font-family:var(--sans);-webkit-font-smoothing:antialiased;overflow:hidden}
button{font:inherit;color:inherit;cursor:pointer}
#app{display:grid;grid-template-rows:auto 1fr auto;height:100dvh;gap:0}
.topbar{display:flex;align-items:center;gap:14px;padding:9px 14px;border-bottom:1px solid var(--line);background:linear-gradient(180deg,rgba(19,32,57,.9),rgba(5,9,15,.75))}
.brand{display:flex;align-items:baseline;gap:9px;flex:0 0 auto}
.brand b{font-family:var(--serif);font-size:23px;letter-spacing:.34em;font-weight:600;color:var(--brass);text-shadow:0 0 22px rgba(200,155,60,.35);padding-left:2px}
.brand span{font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:var(--muted)}
.turnbox{display:flex;align-items:center;gap:9px;padding:5px 12px;border:1px solid var(--line);border-radius:999px;background:rgba(0,0,0,.28)}
.turnbox .dot{width:12px;height:12px;border-radius:50%;box-shadow:0 0 0 2px rgba(0,0,0,.5),0 0 14px currentColor}
.turnbox b{font-size:13px;letter-spacing:.04em}
.turnbox small{font-size:11px;color:var(--muted);font-family:var(--mono)}
.phases{display:flex;align-items:center;gap:0;margin-left:auto}
.phase{font-size:10.5px;letter-spacing:.16em;text-transform:uppercase;color:var(--muted);padding:6px 13px;border:1px solid transparent;position:relative;white-space:nowrap}
.phase+.phase::before{content:"";position:absolute;left:-1px;top:50%;width:6px;height:1px;background:var(--line2)}
.phase.active{color:var(--abyss);background:var(--brass);border-radius:4px;font-weight:700;box-shadow:0 0 18px -4px var(--brass)}
.tools{display:flex;gap:6px;flex:0 0 auto}
.btn{background:rgba(255,255,255,.03);border:1px solid var(--line2);color:var(--bone);padding:7px 12px;border-radius:7px;font-size:12.5px;letter-spacing:.02em;transition:.16s border-color,.16s background,.16s transform}
.btn:hover{background:rgba(200,155,60,.1);border-color:var(--line)}
.btn:active{transform:translateY(1px)}
.btn:disabled{opacity:.32;cursor:not-allowed}
.btn.primary{background:var(--brass);color:#1a1206;border-color:var(--brass);font-weight:700}
.btn.primary:hover{background:#dcae4c}
.btn.good{background:rgba(78,156,139,.16);border-color:rgba(78,156,139,.5);color:#9fe0cf}
.btn.bad{background:rgba(181,68,46,.14);border-color:rgba(181,68,46,.5);color:#f0a795}
.btn.sm{padding:4px 9px;font-size:11.5px;border-radius:6px}
.btn.icon{padding:7px 9px}
select,input[type=text]{background:rgba(0,0,0,.35);border:1px solid var(--line2);color:var(--bone);padding:7px 9px;border-radius:7px;font:inherit;font-size:12.5px}
input[type=range]{accent-color:var(--brass);width:100%}
label.chk{display:flex;align-items:center;gap:9px;font-size:13px;cursor:pointer;padding:6px 0;color:var(--bone)}
label.chk input{accent-color:var(--brass);width:16px;height:16px}
.stage{display:grid;grid-template-columns:262px minmax(0,1fr) 306px;gap:10px;padding:10px;min-height:0}
.col{display:flex;flex-direction:column;gap:10px;min-height:0;overflow:auto;padding-right:2px}
.panel{background:var(--panel);border:1px solid var(--line2);border-radius:12px;backdrop-filter:blur(9px);box-shadow:var(--shadow);overflow:hidden;flex:0 0 auto}
.panel>h3{margin:0;padding:9px 12px;font-family:var(--serif);font-size:11.5px;font-weight:600;letter-spacing:.24em;text-transform:uppercase;color:var(--brass);border-bottom:1px solid var(--line);display:flex;align-items:center;justify-content:space-between;gap:8px}
.panel>h3 .tag{font-family:var(--mono);letter-spacing:0;font-size:10.5px;color:var(--muted);text-transform:none}
.panel .body{padding:10px 12px}
.panel.grow{flex:1 1 auto;display:flex;flex-direction:column;min-height:150px}
.panel.grow .body{overflow:auto;flex:1 1 auto}
.prow{display:grid;grid-template-columns:14px 1fr auto;gap:9px;align-items:center;padding:7px 0;border-bottom:1px dashed rgba(148,170,200,.1)}
.prow:last-child{border-bottom:0}
.prow .dot{width:13px;height:13px;border-radius:3px;box-shadow:0 0 0 1px rgba(0,0,0,.6)}
.prow .nm{font-size:13px;line-height:1.25}
.prow .nm small{display:block;font-size:10px;color:var(--muted);letter-spacing:.06em;text-transform:uppercase}
.prow .st{font-family:var(--mono);font-size:11.5px;color:var(--muted);text-align:right;white-space:nowrap}
.prow.active{background:linear-gradient(90deg,rgba(200,155,60,.12),transparent);margin:0 -12px;padding-left:12px;padding-right:12px;border-radius:6px}
.prow.dead{opacity:.34;filter:grayscale(1)}
.bar{height:3px;border-radius:2px;background:rgba(255,255,255,.07);margin-top:5px;overflow:hidden;grid-column:2/4}
.bar i{display:block;height:100%;border-radius:2px;transition:width .5s cubic-bezier(.2,.8,.2,1)}
.crow{display:flex;align-items:center;gap:8px;padding:5px 0;font-size:12.5px}
.crow .swatch{width:9px;height:9px;border-radius:2px;flex:0 0 auto}
.crow .nm{flex:1 1 auto}
.crow .bonus{font-family:var(--mono);font-size:11px;color:var(--brass)}
.crow .own{font-family:var(--mono);font-size:11px;color:var(--muted)}
.crow.complete .nm{color:#fff;font-weight:600}
.mapwrap{position:relative;border-radius:14px;overflow:hidden;border:1px solid var(--line2);background:radial-gradient(120% 100% at 50% 0%,#16273f 0%,#0a1120 48%,#04070d 100%);box-shadow:var(--shadow);min-height:0}
#map{display:block;width:100%;height:100%;touch-action:none;cursor:grab}
#map.dragging{cursor:grabbing}
.zoomctl{position:absolute;right:10px;bottom:10px;display:flex;flex-direction:column;gap:5px}
.zoomctl .btn{padding:5px 8px;background:rgba(6,10,18,.75)}
.maphint{position:absolute;left:12px;top:10px;font-size:10.5px;letter-spacing:.16em;text-transform:uppercase;color:rgba(230,226,211,.4);pointer-events:none;animation:fadeout .9s ease 7s forwards}
@keyframes fadeout{to{opacity:0}}
.tp{stroke:rgba(4,8,14,.85);stroke-width:1.6;stroke-linejoin:round;stroke-linecap:round;transition:fill .35s ease,opacity .2s}
.tf{fill:#fff;opacity:.12;pointer-events:none;mix-blend-mode:soft-light}
.tsh{fill:#000;opacity:.16;pointer-events:none;mix-blend-mode:multiply}
.tn{font-family:var(--sans);font-size:15px;letter-spacing:.06em;fill:rgba(238,242,250,.62);text-anchor:middle;pointer-events:none;paint-order:stroke;stroke:rgba(3,6,12,.75);stroke-width:3px}
.terr{cursor:pointer}
.terr .tp{filter:saturate(1.05)}
.terr:hover .tp{stroke:#fff;stroke-width:2.4}
.terr.sel .tp{stroke:var(--brass);stroke-width:3.4;filter:drop-shadow(0 0 12px rgba(200,155,60,.85))}
.terr.tgt .tp{stroke:var(--rust);stroke-width:3;filter:drop-shadow(0 0 10px rgba(181,68,46,.8))}
.terr.dim{opacity:.34}
.terr.pulse .tp{animation:pulse 1.5s ease-in-out infinite}
@keyframes pulse{0%,100%{stroke-opacity:.55}50%{stroke-opacity:1}}
.badge circle{stroke:rgba(3,7,14,.9);stroke-width:1.6}
.badge text{font-family:var(--mono);font-size:17px;font-weight:700;text-anchor:middle;dominant-baseline:central;pointer-events:none}
.link{stroke:rgba(160,190,220,.16);stroke-width:1.3;fill:none}
.link.sea{stroke:rgba(200,155,60,.26);stroke-dasharray:5 6}
.clabel{font-family:var(--serif);font-size:17px;letter-spacing:.34em;text-transform:uppercase;text-anchor:middle;pointer-events:none;opacity:.5}
.cbonus{font-family:var(--mono);font-size:13px;letter-spacing:.1em;text-anchor:middle;pointer-events:none;opacity:.42}
.ripple{fill:none;stroke-width:3;pointer-events:none}
#tooltip{position:absolute;pointer-events:none;z-index:20;opacity:0;transform:translateY(4px);transition:opacity .12s,transform .12s;background:rgba(6,11,20,.95);border:1px solid var(--line);border-radius:9px;padding:8px 11px;font-size:12.5px;min-width:150px;box-shadow:var(--shadow)}
#tooltip.on{opacity:1;transform:none}
#tooltip b{display:block;font-family:var(--serif);letter-spacing:.1em;text-transform:uppercase;font-size:12px;color:var(--brass);margin-bottom:3px}
#tooltip .r{display:flex;justify-content:space-between;gap:14px;color:var(--muted);font-size:11.5px;line-height:1.7}
#tooltip .r i{font-style:normal;color:var(--bone);font-family:var(--mono)}
.obj{font-size:13px;line-height:1.55;color:var(--bone)}
.obj .hidden{color:var(--muted);font-style:italic}
.hand{display:flex;flex-wrap:wrap;gap:7px}
.tcard{width:66px;border:1px solid var(--line2);border-radius:8px;padding:6px 5px;text-align:center;background:linear-gradient(160deg,rgba(255,255,255,.05),rgba(0,0,0,.25));cursor:pointer;transition:.15s}
.tcard:hover{border-color:var(--brass)}
.tcard.on{border-color:var(--brass);background:rgba(200,155,60,.16);box-shadow:0 0 14px -3px var(--brass)}
.tcard .sym{font-size:19px;line-height:1;color:var(--brass)}
.tcard .nm{font-size:8.8px;letter-spacing:.04em;text-transform:uppercase;color:var(--muted);margin-top:5px;line-height:1.25;height:22px;overflow:hidden}
.tcard.mine .nm{color:var(--verdigris)}
.power{display:flex;gap:9px;align-items:flex-start;padding:8px;border:1px solid var(--line2);border-radius:9px;margin-bottom:7px;background:rgba(255,255,255,.025)}
.power .ico{font-size:19px;line-height:1.1}
.power .t{font-size:12.5px;font-weight:600;letter-spacing:.02em}
.power .d{font-size:11px;color:var(--muted);line-height:1.45;margin-top:2px}
.log{font-size:12px;line-height:1.5}
.logline{display:flex;gap:7px;padding:4px 0;border-bottom:1px dashed rgba(148,170,200,.08)}
.logline .d{width:7px;height:7px;border-radius:50%;margin-top:5px;flex:0 0 auto}
.logline em{font-style:normal;color:var(--brass)}
.logline.sys{color:var(--muted)}
.bottombar{display:flex;align-items:center;gap:12px;padding:9px 14px;border-top:1px solid var(--line);background:linear-gradient(0deg,rgba(19,32,57,.9),rgba(5,9,15,.7))}
#hint{font-size:12.5px;color:var(--muted);flex:1 1 auto;min-width:0}
#hint b{color:var(--bone);font-weight:600}
.reinf{display:flex;align-items:center;gap:9px;padding:6px 13px;border-radius:999px;border:1px solid var(--line);background:rgba(200,155,60,.1);font-size:12.5px}
.reinf b{font-family:var(--mono);font-size:19px;color:var(--brass);line-height:1}
.actions{display:flex;gap:7px;flex-wrap:wrap;justify-content:flex-end}
.backdrop{position:fixed;inset:0;background:rgba(3,6,12,.78);backdrop-filter:blur(6px);display:none;align-items:center;justify-content:center;z-index:50;padding:16px}
.backdrop.on{display:flex}
.modal{width:min(680px,100%);max-height:90dvh;overflow:auto;background:linear-gradient(180deg,#101b2f,#080d18);border:1px solid var(--line);border-radius:16px;box-shadow:0 40px 90px -30px #000;animation:rise .28s cubic-bezier(.2,.9,.2,1)}
.modal.wide{width:min(880px,100%)}
.modal.slim{width:min(460px,100%)}
@keyframes rise{from{opacity:0;transform:translateY(16px) scale(.98)}}
.modal header{padding:16px 20px 12px;border-bottom:1px solid var(--line)}
.modal header h2{margin:0;font-family:var(--serif);font-size:20px;font-weight:600;letter-spacing:.2em;text-transform:uppercase;color:var(--brass)}
.modal header p{margin:5px 0 0;font-size:12.5px;color:var(--muted);line-height:1.55}
.modal .content{padding:16px 20px}
.modal footer{padding:12px 20px 16px;display:flex;gap:8px;justify-content:flex-end;flex-wrap:wrap}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.field{display:flex;flex-direction:column;gap:6px;margin-bottom:12px}
.field>span{font-size:10.5px;letter-spacing:.18em;text-transform:uppercase;color:var(--muted)}
.swatches{display:flex;gap:8px;flex-wrap:wrap}
.sw{width:38px;height:38px;border-radius:9px;border:2px solid transparent;cursor:pointer;transition:.15s}
.sw.on{border-color:var(--brass);transform:scale(1.08);box-shadow:0 0 16px -3px var(--brass)}
.rules{font-size:13.5px;line-height:1.7;color:#cfd8e6}
.rules h4{font-family:var(--serif);letter-spacing:.16em;text-transform:uppercase;color:var(--brass);font-size:12px;margin:20px 0 7px}
.rules h4:first-child{margin-top:0}
.rules code{font-family:var(--mono);font-size:12px;background:rgba(200,155,60,.1);padding:1px 5px;border-radius:4px;color:var(--brass)}
.rules ul{margin:6px 0;padding-left:19px}
.rules li{margin:3px 0}
.rules table{width:100%;border-collapse:collapse;font-family:var(--mono);font-size:12px;margin-top:6px}
.rules td,.rules th{border:1px solid var(--line2);padding:5px 8px;text-align:left}
.rules th{color:var(--brass);font-weight:600}
.duel{display:grid;grid-template-columns:1fr 64px 1fr;gap:10px;align-items:center}
.side{text-align:center;padding:12px;border-radius:12px;border:1px solid var(--line2);background:rgba(0,0,0,.25)}
.side .who{font-size:10.5px;letter-spacing:.2em;text-transform:uppercase;color:var(--muted)}
.side .terr-nm{font-family:var(--serif);font-size:16.5px;letter-spacing:.09em;margin:3px 0 2px}
.side .armies{font-family:var(--mono);font-size:13px;color:var(--muted)}
.side .armies b{color:var(--bone);font-size:19px}
.vs{text-align:center;font-family:var(--serif);letter-spacing:.16em;color:var(--brass);font-size:14px}
.odds{font-family:var(--mono);font-size:12px;color:var(--muted);text-align:center;margin-top:9px}
.odds b{color:var(--brass);font-size:15px}
.oddsbar{height:5px;border-radius:3px;background:rgba(181,68,46,.4);overflow:hidden;margin-top:6px}
.oddsbar i{display:block;height:100%;background:var(--verdigris);transition:width .4s}
.dicerow{display:flex;gap:8px;justify-content:center;margin-top:11px;min-height:44px}
.die{width:40px;height:40px;border-radius:9px;display:grid;grid-template:repeat(3,1fr)/repeat(3,1fr);padding:5px;background:linear-gradient(150deg,#c94a36,#7c2318);box-shadow:0 5px 12px -4px #000,inset 0 -2px 0 rgba(0,0,0,.28),inset 0 1px 0 rgba(255,255,255,.18);border:1px solid rgba(0,0,0,.35)}
.die.def{background:linear-gradient(150deg,#e0b13e,#a97a12);box-shadow:0 5px 12px -4px #000,inset 0 -2px 0 rgba(0,0,0,.24),inset 0 1px 0 rgba(255,255,255,.3)}
.die .pip{width:7px;height:7px;border-radius:50%;background:#f5efe4;align-self:center;justify-self:center;box-shadow:inset 0 1px 1px rgba(0,0,0,.4)}
.die.def .pip{background:#2a1d08}
.die.faded{opacity:.32}
.die.win{outline:2px solid var(--verdigris);outline-offset:2px}
.die.lose{outline:2px solid #050505;outline-offset:2px;opacity:.6;filter:saturate(.4)}
.die.rolling{animation:tumble .55s cubic-bezier(.36,.07,.19,.97) infinite}
.die.settle{animation:settle .32s ease-out}
@keyframes tumble{0%{transform:translateY(0) rotate(0) scale(1)}20%{transform:translateY(-10px) rotate(-95deg) scale(1.06)}45%{transform:translateY(2px) rotate(160deg) scale(.96)}70%{transform:translateY(-6px) rotate(280deg) scale(1.04)}100%{transform:translateY(0) rotate(360deg) scale(1)}}
@keyframes settle{0%{transform:scale(1.35);filter:brightness(1.6)}60%{transform:scale(.94)}100%{transform:scale(1);filter:brightness(1)}}
.roundtag{font-family:var(--mono);font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);text-align:center;margin-top:10px}
.blog{margin-top:12px;max-height:132px;overflow:auto;font-family:var(--mono);font-size:11.5px;color:var(--muted);line-height:1.7;border-top:1px solid var(--line2);padding-top:8px}
.blog .win{color:var(--verdigris)}
.blog .lose{color:#f0a795}
.stat{display:flex;align-items:center;gap:9px;margin-bottom:9px}
.stat .nm{width:104px;font-size:12.5px}
.stat .track{flex:1;height:16px;background:rgba(255,255,255,.05);border-radius:4px;overflow:hidden;display:flex}
.stat .track i{display:block;height:100%}
.stat .v{font-family:var(--mono);font-size:12px;color:var(--muted);width:78px;text-align:right}
.victory-sub{font-family:var(--serif);font-size:15px;letter-spacing:.1em;color:var(--bone);text-align:center;line-height:1.7}
.crown{font-size:52px;text-align:center;margin:6px 0 2px}
.tabs{display:none;gap:6px;padding:0 10px 8px}
.tabs .btn{flex:1}
@media (max-width:1180px){.stage{grid-template-columns:1fr;grid-template-rows:minmax(0,1fr)}.col{display:none;max-height:38dvh}.col.show{display:flex}.tabs{display:flex}.brand span{display:none}.phases{gap:0}.phase{padding:6px 8px;font-size:9.5px;letter-spacing:.09em}}
@media (max-width:720px){.topbar{flex-wrap:wrap;gap:8px;padding:8px 10px}.phases{order:5;width:100%;justify-content:space-between}.tools{margin-left:auto}.brand b{font-size:19px;letter-spacing:.24em}.bottombar{flex-wrap:wrap}.actions{width:100%;justify-content:stretch}.actions .btn{flex:1}.duel{grid-template-columns:1fr;gap:8px}.vs{padding:2px}}
@media (prefers-reduced-motion:reduce){*{animation:none!important;transition:none!important}}
</style>
</head>
<body>
<div id="app">
  <div class="topbar">
    <div class="brand"><b>WAR</b><span>Estratégia&nbsp;e&nbsp;Conquista</span></div>
    <div class="turnbox">
      <i class="dot" id="curDot"></i>
      <b id="curName">—</b>
      <small id="roundLbl">Rodada 1</small>
    </div>
    <div class="phases">
      <div class="phase" data-p="reforco">Reforço</div>
      <div class="phase" data-p="ataque">Ataque</div>
      <div class="phase" data-p="remanejar">Remanejamento</div>
    </div>
    <div class="tools">
      <button class="btn icon" id="btnSound" title="Som">🔊</button>
      <select id="selSpeed" title="Velocidade da IA">
        <option value="rapido">Rápido</option>
        <option value="normal" selected>Normal</option>
        <option value="lento">Lento</option>
      </select>
      <button class="btn" id="btnStats">Estatísticas</button>
      <button class="btn" id="btnRules">Regras</button>
      <button class="btn bad" id="btnNew">Nova partida</button>
    </div>
  </div>
  <div class="tabs">
    <button class="btn sm" data-tab="left">Exércitos</button>
    <button class="btn sm" data-tab="map">Mapa</button>
    <button class="btn sm" data-tab="right">Comando</button>
  </div>
  <div class="stage">
    <div class="col left" id="colLeft">
      <div class="panel">
        <h3>Forças em campo <span class="tag" id="tagAlive"></span></h3>
        <div class="body" id="players"></div>
      </div>
      <div class="panel grow">
        <h3>Continentes</h3>
        <div class="body" id="conts"></div>
      </div>
      <div class="panel">
        <h3>Exibição</h3>
        <div class="body">
          <label class="chk"><input type="checkbox" id="optLinks" checked> Rotas de fronteira</label>
          <label class="chk"><input type="checkbox" id="optNames" checked> Nomes dos territórios</label>
          <label class="chk"><input type="checkbox" id="optOdds" checked> Prévia de chance de vitória</label>
        </div>
      </div>
    </div>
    <div class="mapwrap" id="mapwrap">
      <svg id="map" viewBox="0 0 1600 900" preserveAspectRatio="xMidYMid meet"></svg>
      <div class="maphint" id="maphint">Arraste para mover · role para ampliar</div>
      <div class="zoomctl">
        <button class="btn" id="zIn">＋</button>
        <button class="btn" id="zOut">−</button>
        <button class="btn" id="zRst">⟳</button>
      </div>
      <div id="tooltip"></div>
    </div>
    <div class="col right" id="colRight">
      <div class="panel">
        <h3>Objetivo secreto <span class="tag" id="tagObjMode"></span></h3>
        <div class="body obj" id="objective"></div>
      </div>
      <div class="panel">
        <h3>Cartas de território <span class="tag" id="tagCards"></span></h3>
        <div class="body">
