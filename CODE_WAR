function centroid(pts){
  let a=0,cx=0,cy=0;
  for(let i=0;i<pts.length;i++){
    const [x1,y1]=pts[i],[x2,y2]=pts[(i+1)%pts.length];
    const f=x1*y2-x2*y1; a+=f; cx+=(x1+x2)*f; cy+=(y1+y2)*f;
  }
  a*=.5; return [cx/(6*a), cy/(6*a)];
}
