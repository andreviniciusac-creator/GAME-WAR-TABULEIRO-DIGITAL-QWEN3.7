/* ==================================================================
   12. AÇÕES DO RODAPÉ / FLUXO DE FASES
   ================================================================== */
function setHint(h){ $('#hint').innerHTML=h; }
function renderActions(){
  const box=$('#actions'); box.innerHTML='';
  const p=cur();
  $('#reinfBox').hidden = !(p===me() && (S.phase==='reforco'||S.phase==='inicial') && !S.gameOver);
  $('#reinfN').textContent=S.reinf;

  if(S.gameOver){ setHint('A guerra terminou.'); return; }
  if(p.isAI){ setHint(`<b>${p.name}</b> está deliberando…`); return; }
  if(S.busy) return;

  const add=(txt,cls,fn,dis)=>{const b=document.createElement('button');b.className='btn '+cls;b.textContent=txt;b.disabled=!!dis;b.onclick=fn;box.appendChild(b);return b;};

  if(S.phase==='inicial'){
    setHint(S.reinf ? `Posicionamento inicial — distribua <b>${S.reinf}</b> exércitos. <b>Clique direito</b> desfaz.`
                    : 'Tropas iniciais posicionadas.');
    add('Distribuir automaticamente','', ()=>autoPlace(), !S.reinf);
    add('Concluir posicionamento','primary', ()=>nextDeploy(), S.reinf>0);
    return;
  }
  if(S.phase==='reforco'){
    if(S.mustTrade){ setHint('Você tem <b>5 cartas</b>. Selecione um conjunto válido e troque antes de posicionar.'); return; }
    setHint(S.reinf ? 'Clique nos seus territórios para posicionar. <b>Clique direito</b> desfaz.' : 'Todos os exércitos posicionados.');
    add('Distribuir automaticamente','', ()=>{autoPlace();}, !S.reinf);
    add('Avançar para o ataque','primary', ()=>{ S.phase='ataque'; S.sel=null; sfx.turn(); render(); }, S.reinf>0);
  }
  else if(S.phase==='ataque'){
    setHint(S.sel ? `Atacando a partir de <b>${byId[S.sel].n}</b>. Escolha um vizinho inimigo.`
                  : 'Selecione um território seu com <b>2 ou mais</b> exércitos.');
    if(S.sel) add('Cancelar seleção','',()=>{S.sel=null;render();});
    add('Ir para remanejamento','primary',()=>{ S.phase='remanejar'; S.sel=null; S.srcUsed=new Set(); S.gotArmies=new Set(); sfx.turn(); render(); });
  }
  else if(S.phase==='remanejar'){
    setHint(S.sel ? `Movendo de <b>${byId[S.sel].n}</b>. Escolha um território seu adjacente.`
                  : 'Mova exércitos entre territórios seus adjacentes. Cada território pode ser origem uma vez.');
    if(S.sel) add('Cancelar seleção','',()=>{S.sel=null;render();});
    add('Encerrar turno','primary',()=>endTurn());
  }
}

/* ---------- cliques no mapa ---------- */
function onTerrClick(id){
  if(S.gameOver||S.busy) return;
  const p=cur(); if(p.isAI) return;
  if(S.pick){ handlePick(id); return; }
  const st=S.terr[id];

  if(S.phase==='reforco'||S.phase==='inicial'){
    if(S.phase==='reforco' && S.mustTrade){ shake('#btnTrade'); return; }
    if(st.o!==p.i || S.reinf<=0) return;
    st.a++; S.reinf--; S.placed[id]=(S.placed[id]||0)+1; sfx.place(); flash(id); render();
  }
  else if(S.phase==='ataque'){
    if(!S.sel){
      if(st.o!==p.i || st.a<2 || !enemiesOf(id,p).length) return;
      S.sel=id; sfx.click(); render();
    } else if(id===S.sel){ S.sel=null; render(); }
    else if(st.o===p.i){
      if(st.a>=2 && enemiesOf(id,p).length){ S.sel=id; sfx.click(); render(); }
    } else if(ADJ[S.sel].includes(id)){
      if(p.eff.cannotAttack===st.o){ toastLog('Trégua em vigor: você não pode atacar '+S.players[st.o].name+' neste turno.'); return; }
      openBattle(S.sel,id);
    }
  }
  else if(S.phase==='remanejar'){
    if(!S.sel){
      if(st.o!==p.i||st.a<2||S.srcUsed.has(id)||S.gotArmies.has(id)) return;
      if(!ADJ[id].some(x=>isMine(x,p))) return;
      S.sel=id; sfx.click(); render();
    } else if(id===S.sel){ S.sel=null; render(); }
    else if(st.o===p.i && ADJ[S.sel].includes(id)){
      askMove('Deslocar exércitos', `${byId[S.sel].n} → ${byId[id].n}`, 1, armies(S.sel)-1, n=>{
        S.terr[S.sel].a-=n; st.a+=n; S.srcUsed.add(S.sel); S.gotArmies.add(id);
        log(p, `remanejou <em>${n}</em> exército(s) de ${byId[S.sel].n} para ${byId[id].n}.`);
        S.sel=null; sfx.place(); render();
      });
    } else if(st.o===p.i && armies(id)>=2 && !S.srcUsed.has(id) && !S.gotArmies.has(id)){ S.sel=id; render(); }
  }
}
function onTerrRightClick(id){
  if(S.pick){ S.pick=null; render(); return; }
  if((S.phase!=='reforco'&&S.phase!=='inicial')||S.busy||cur()!==me()) return;
  if(!S.placed[id]) return;
  S.placed[id]--; S.terr[id].a--; S.reinf++; sfx.click(); render();
}
function shake(sel){ const e=$(sel); if(!e)return; e.animate([{transform:'translateX(0)'},{transform:'translateX(-6px)'},{transform:'translateX(6px)'},{transform:'translateX(0)'}],{duration:230}); }
function toastLog(t){ logSys(t); }

function autoPlace(){
  const p=me();
  while(S.reinf>0){
    const cands = ownedBy(p).filter(id=>enemiesOf(id,p).length);
    const pool = cands.length?cands:ownedBy(p);
    let best=pool[0], bs=-1e9;
    pool.forEach(id=>{
      const threat = enemiesOf(id,p).reduce((s,x)=>s+armies(x),0)-armies(id);
      const s = threat + (S.placed[id]||0)*-0.7 + Math.random()*.4;
      if(s>bs){bs=s;best=id;}
    });
    S.terr[best].a++; S.placed[best]=(S.placed[best]||0)+1; S.reinf--;
  }
  sfx.place(); render();
}

