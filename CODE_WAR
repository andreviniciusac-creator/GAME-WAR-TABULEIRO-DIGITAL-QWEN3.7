/* ==================================================================
   16. INTELIGÊNCIA ARTIFICIAL
   ================================================================== */
const threat = (id,p)=>enemiesOf(id,p).reduce((s,x)=>s+armies(x),0);
const contTotal = c=>TERRS.filter(t=>t.c===c).length;
function contPressure(p,c){ return contCount(p,c)/contTotal(c); }
function objWeightTerr(p,id){
  const o=p.obj; if(!o) return .5;
  const t=byId[id];
  if(o.type==='cont')    return o.conts.includes(t.c) ? 2.4 : .3;
  if(o.type==='terr')    return 1;
  if(o.type==='total')   return 1;
  if(o.type==='destroy'){
    const tgt=S.players.find(x=>x.color.id===o.color);
    if(tgt && tgt.alive && tgt.i!==p.i && S.terr[id].o===tgt.i) return 2.8;
    return .6;
  }
  return .5;
}

function aiTrade(p,L){
  let guard=0;
  while(p.cards.length>=3 && guard++<5){
    const set=findSet(p.cards);
    if(!set) break;
    const forced = p.cards.length>=5;
    if(!forced){
      const val=tradeValue(S.tradeCount+1);
      const want = Math.random()<L.trade && (val>=8 || p.cards.length>=4 || L.hunt);
      if(!want) break;
    }
    doTrade(p,set);
  }
}
function aiUsePowers(p,L,when,ctx){
  if(!S.settings.powers || !p.powers.length) return;
  if(Math.random()>L.powerUse) return;
  const has=id=>p.powers.indexOf(id);
  const use=id=>{ const i=has(id); if(i<0) return false; p.powers.splice(i,1); log(p,`usou <em>${POWERS.find(x=>x.id===id).n}</em>.`); return true; };

  if(when==='reforco'){
    if(has('mobilizacao')>=0 && use('mobilizacao')) S.reinf+=4;
    if(has('sabotagem')>=0){
      const targets=[]; ownedBy(p).forEach(id=>enemiesOf(id,p).forEach(x=>targets.push(x)));
      if(targets.length){
        const t=targets.sort((a,b)=>armies(b)-armies(a))[0];
        if(armies(t)>=3 && use('sabotagem')){ S.terr[t].a=Math.max(1,armies(t)-2); flash(t); }
      }
    }
    if(has('muralha')>=0){
      const my=ownedBy(p).reduce((s,id)=>s+armies(id),0);
      const en=S.players.filter(x=>x.alive&&x!==p).reduce((m,x)=>Math.max(m,ownedBy(x).reduce((s,id)=>s+armies(id),0)),0);
      if(en>my*1.2 && use('muralha')) p.eff.wall=true;
    }
    if(has('tregua')>=0){
      const lead=S.players.filter(x=>x.alive&&x!==p).sort((a,b)=>ownedBy(b).length-ownedBy(a).length)[0];
      if(lead && ownedBy(lead).length>ownedBy(p).length && use('tregua')) lead.eff.cannotAttack=p.i;
    }
    if(has('espionagem')>=0 && p.powers.length>=3) use('espionagem');
  }
  if(when==='preattack' && ctx){
    if(has('blitz')>=0 && !p.eff.blitz && ctx.pc>.5 && use('blitz')) p.eff.blitz=true;
    if(has('artilharia')>=0 && ctx.pc>.35 && ctx.pc<.82 && ctx.val>2 && use('artilharia')) p.eff.artilharia=true;
  }
  if(when==='fortify' && has('ponte')>=0){
    const own=ownedBy(p);
    const src=own.filter(id=>!enemiesOf(id,p).length && armies(id)>2).sort((a,b)=>armies(b)-armies(a))[0];
    const dst=own.filter(id=>enemiesOf(id,p).length).sort((a,b)=>(threat(b,p)-armies(b))-(threat(a,p)-armies(a)))[0];
    if(src&&dst&&src!==dst&&use('ponte')){ const n=Math.min(5,armies(src)-1); S.terr[src].a-=n; S.terr[dst].a+=n; }
  }
}
async function aiPlace(p,K,L){
  let guard=0;
  while(S.reinf>0 && guard++<60){
    const own=ownedBy(p);
    const borders=own.filter(id=>enemiesOf(id,p).length);
    const pool=borders.length?borders:own;
    let best=pool[0], bs=-1e9;
    pool.forEach(id=>{
      const t=byId[id];
      let s = threat(id,p) - armies(id)*.55;
      s += objWeightTerr(p,id)*1.6*K.objW;
      const cp=contPressure(p,t.c); s += cp*cp*3.2*K.greed;
      if(contOwned(p,t.c)) s += 1.2;
      const weakest = enemiesOf(id,p).reduce((m,x)=>Math.min(m,armies(x)),99);
      if(weakest<99) s += (6/(1+weakest))*1.1*K.greed;
      s += (Math.random()-.5)*L.noise*4;
      if(s>bs){bs=s;best=id;}
    });
    const chunk=Math.min(S.reinf, Math.max(1, Math.ceil(S.reinf/3)));
    S.terr[best].a+=chunk; S.reinf-=chunk;
    flash(best); render(); await wait(150);
  }
}
async function aiAttack(p,K,L){
  const thr=K.thr;
  const armOf=q=>ownedBy(q).reduce((s,id)=>s+armies(id),0);
  let atks=0;
  const maxAtk = K.maxAtk + (ownedBy(p).length>21?10:0) + (L.hunt?6:0);
  while(atks<maxAtk && !S.gameOver){
    const cands=[];
    ownedBy(p).filter(id=>armies(id)>=2).forEach(from=>{
      enemiesOf(from,p).forEach(to=>{
        const dOwner=S.players[S.terr[to].o];
        if(p.eff.cannotAttack===dOwner.i) return;
        const A=armies(from), D=armies(to), pc=pConquer(A,D), t=byId[to];
        let val=1;
        val += objWeightTerr(p,to)*1.5*K.objW;
        val += contPressure(p,t.c)*2.2*K.greed;
        if(contCount(p,t.c)===contTotal(t.c)-1) val += 3.6;
        if(contOwned(dOwner,t.c)) val += 1.8;
        if(ownedBy(dOwner).length===1) val += 2.4 + (L.hunt ? dOwner.cards.length*.9 : 0);
        if(!S.conquered) val += 1.4;

        let winning=false;
        if(L.hunt){
          const o0=S.terr[to].o, a0=S.terr[to].a;
          S.terr[to].o=p.i; S.terr[to].a=Math.max(1,Math.min(3,A-1));
          winning = objectiveDone(p);
          S.terr[to].o=o0; S.terr[to].a=a0;
          if(winning) val += 30;
        }

        const expo = ADJ[to].filter(x=>x!==from && S.terr[x].o!==p.i).reduce((s,x)=>s+armies(x),0);
        let score = pc*val - (1-pc)*(1.1/K.greed) - L.expo*expo*.055;
        score += (Math.random()-.5)*L.noise*2.2;
        cands.push({from,to,pc,score,val,winning,owner:dOwner});
      });
    });
    if(!cands.length) break;

    const mine = armOf(p), cache = {};
    const totalEnemy = S.players.filter(q=>q.alive&&q!==p).reduce((s,q)=>s+armOf(q),0);
    const baseNeed = S.conquered ? thr : Math.min(thr,.34);
    const dominant = ownedBy(p).length > 25;
    cands.forEach(c=>{
      const oa = cache[c.owner.i] ?? (cache[c.owner.i]=armOf(c.owner));
      let need = baseNeed;
      if(mine > oa*1.8) need -= .10;
      if(ownedBy(c.owner).length===1) need -= .06;
      if(dominant) need -= .05;
      if(mine > totalEnemy) need -= .08;
      if(c.winning) need -= .14;
      if(L.guard){
        const maxAdj = enemiesOf(c.from,p).reduce((m,x)=>Math.max(m,armies(x)),0);
        if(armies(c.from)-1 < maxAdj*.7) need += .12*L.guard;
      }
      c.need = Math.max(.20, need);
    });

    const viable = cands.filter(c=>c.pc>=c.need);
    if(!viable.length) break;
    viable.sort((a,b)=>b.score-a.score);
    let pick=viable[0];
    if(L.blunder && Math.random()<L.blunder && viable.length>1) pick=viable[1+rnd(Math.min(3,viable.length-1))];

    aiUsePowers(p,L,'preattack',pick);
    await aiBattle(p,pick.from,pick.to,L);
    atks++;
    if(S.gameOver) return;
    render(); await wait(190);
  }
}
async function aiBattle(p,from,to,L){
  const d=S.players[S.terr[to].o];
  let guard=0;
  while(armies(from)>=2 && S.terr[to].o!==p.i && guard++<80 && !S.gameOver){
    const mods={extraDie:!!p.eff.artilharia, wall:!!d.eff.wall};
    const r=resolveRound(armies(from),armies(to),mods);
    p.eff.artilharia=false;
    S.terr[from].a-=r.aLoss; S.terr[to].a-=r.dLoss;
    p.battles++; p.lost+=r.aLoss; d.lost+=r.dLoss;
    flash(to); sfx.dice();
    if(armies(to)<=0){
      const maxMove=Math.min(3,armies(from)-1);
      const minMove=clamp(Math.min(3,r.aKept.length),1,maxMove);
      const srcExposed = enemiesOf(from,p).filter(x=>x!==to).length>0;
      const n = srcExposed
        ? clamp(Math.ceil((armies(from)-1)/2), minMove, maxMove)
        : maxMove;
      S.terr[to].o=p.i; S.terr[to].a=0;
      S.conquered++; p.conq++;
      log(p,`conquistou <em>${byId[to].n}</em> de ${d.name}.`);
      applyConquest(from,to,p,d,n);
      ripple(to,p.color.hex); sfx.conq(); render();
      checkVictory();
      return;
    }
    if(pConquer(armies(from),armies(to))<.20) break;
    render(); await wait(130);
  }
  sfx.hit();
}
async function aiFortify(p,K,L){
  aiUsePowers(p,L,'fortify');
  const maxMoves=Math.max(1,Math.round(2*K.fort));
  let moves=0;
  while(moves<maxMoves){
    const own=ownedBy(p);
    const sources=own.filter(id=>armies(id)>1 && !S.srcUsed.has(id) && !S.gotArmies.has(id)
      && !enemiesOf(id,p).length && ADJ[id].some(x=>isMine(x,p)));
    if(!sources.length) break;
    let best=null,bs=-1e9;
    sources.forEach(src=>ADJ[src].filter(x=>isMine(x,p)).forEach(dst=>{
      let s = threat(dst,p) - armies(dst) + objWeightTerr(p,dst)*1.2*K.objW;
      if(!enemiesOf(dst,p).length) s -= 4;
      s *= L.fortifyQ; s += (Math.random()-.5)*L.noise*3;
      if(s>bs){bs=s;best={src,dst};}
    }));
    if(!best || bs<.3) break;
    const n=armies(best.src)-1;
    S.terr[best.src].a-=n; S.terr[best.dst].a+=n;
    S.srcUsed.add(best.src); S.gotArmies.add(best.dst);
    log(p,`remanejou <em>${n}</em> exército(s) para ${byId[best.dst].n}.`);
    render(); await wait(190); moves++;
  }
}
async function aiTurn(p){
  const K=PERSONAS[p.persona], L=LEVELS[p.level], epoch=S.epoch;
  const stale=()=>S.epoch!==epoch;
  await wait(420); if(stale())return;
  aiTrade(p,L); render(); await wait(230); if(stale())return;
  aiUsePowers(p,L,'reforco'); render();
  await aiPlace(p,K,L); if(stale())return;
  if(S.gameOver) return;
  S.phase='ataque'; render(); await wait(240); if(stale())return;
  await aiAttack(p,K,L); if(stale())return;
  if(S.gameOver) return;
  S.phase='remanejar'; S.srcUsed=new Set(); S.gotArmies=new Set(); render(); await wait(220); if(stale())return;
  await aiFortify(p,K,L); if(stale())return;
  await wait(240);
}

