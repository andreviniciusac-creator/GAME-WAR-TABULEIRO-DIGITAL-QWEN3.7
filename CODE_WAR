    rolls.dRaw.forEach(v=>{ const e=dieEl(v,true); e.classList.add('settle'); dD.appendChild(e); });
    for(let i=0;i<rolls.cmp;i++){
      const ae=dA.children[i], de=dD.children[i];
      if(rolls.pairs[i]==='a'){ ae.classList.add('win'); de.classList.add('lose'); }
