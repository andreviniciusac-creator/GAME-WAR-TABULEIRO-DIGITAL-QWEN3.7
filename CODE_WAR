/* Projeção Mercator simples */
function mercatorProject(lon, lat) {
  const x = (lon + 180) * (1600 / 360);
  const y = (180 / Math.PI) * Math.log(Math.tan(Math.PI / 4 + (lat * Math.PI / 180) / 2));
  const yMerc = 450 - y * (900 / 180);
  return [x, yMerc];
}

/* Converte coordenadas GeoJSON para path SVG */
function geoJSONtoPath(coordinates) {
  if (!coordinates || coordinates.length === 0) return '';
  let d = '';
  for (const ring of coordinates) {
    for (let i = 0; i < ring.length; i++) {
      const [x, y] = mercatorProject(ring[i][0], ring[i][1]);
      d += (i === 0 ? 'M' : 'L') + x.toFixed(1) + ' ' + y.toFixed(1) + ' ';
    }
    d += 'Z ';
  }
  return d;
}

/* Calcula centroide de um conjunto de polígonos */
function calculateCentroid(geoData) {
  let totalX = 0, totalY = 0, count = 0;
  for (const feature of geoData) {
    if (feature.geometry.type === 'Polygon') {
      for (const ring of feature.geometry.coordinates) {
        for (const coord of ring) {
          const [x, y] = mercatorProject(coord[0], coord[1]);
          totalX += x;
          totalY += y;
          count++;
        }
      }
    } else if (feature.geometry.type === 'MultiPolygon') {
      for (const polygon of feature.geometry.coordinates) {
        for (const ring of polygon) {
          for (const coord of ring) {
            const [x, y] = mercatorProject(coord[0], coord[1]);
            totalX += x;
            totalY += y;
            count++;
          }
        }
      }
    }
  }
  return count > 0 ? [totalX / count, totalY / count] : [800, 450];
}

