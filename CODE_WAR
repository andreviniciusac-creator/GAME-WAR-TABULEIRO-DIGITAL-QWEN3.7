  render();
}

const RULES_HTML = `
<h4>Objetivo do jogo</h4>
<p>Vence quem cumprir primeiro o seu <b>objetivo secreto</b> — ou quem conquistar os 42 territórios. Se restar apenas um exército em campo, ele vence por eliminação.</p>

