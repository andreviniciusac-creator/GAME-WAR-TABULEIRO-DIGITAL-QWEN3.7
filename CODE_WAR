function usePower(p,idx){
  const pid=p.powers[idx], pw=POWERS.find(x=>x.id===pid);
  const consume=()=>{ p.powers.splice(idx,1); log(p,`usou <em>${pw.n}</em>.`); sfx.click(); render(); };
  if(pid==='mobilizacao'){ if(S.phase!=='reforco') return; S.reinf+=4; consume(); }
  else if(pid==='artilharia'){ p.eff.artilharia=true; consume(); }
  else if(pid==='muralha'){ p.eff.wall=true; consume(); }
  else if(pid==='blitz'){ p.eff.blitz=true; consume(); }
  else if(pid==='espionagem'){
    const opts=S.players.filter(x=>x.alive&&x!==p).map(x=>({label:`<b style="color:${x.color.hex}">${x.name}</b>`,value:x.i}));
    askChoose('Espionagem','Escolha o adversário a investigar.',opts,i=>{
      const tgt=S.players[i]; p.revealed=p.revealed||{}; p.revealed[i]=objectiveText(tgt);
      consume(); logSys(`Inteligência: o objetivo de <em>${tgt.name}</em> foi revelado.`);
    });
  }
  else if(pid==='tregua'){
    const opts=S.players.filter(x=>x.alive&&x!==p).map(x=>({label:`<b style="color:${x.color.hex}">${x.name}</b>`,value:x.i}));
    askChoose('Trégua','O adversário escolhido não poderá atacá-lo no próximo turno dele.',opts,i=>{
      S.players[i].eff.cannotAttack=p.i; consume();
    });
  }
  else if(pid==='sabotagem'){ S.pick={mode:'sabotagem',idx}; setHint('<b>Sabotagem:</b> clique num território inimigo (clique direito cancela).'); }
  else if(pid==='ponte'){ S.pick={mode:'ponte1',idx}; setHint('<b>Ponte aérea:</b> clique no território de origem.'); }
}
function handlePick(id){
  const p=me(), pk=S.pick;
  if(pk.mode==='sabotagem'){
    if(S.terr[id].o===p.i) return;
    S.terr[id].a=Math.max(1,armies(id)-2);
    p.powers.splice(pk.idx,1); log(p,`sabotou <em>${byId[id].n}</em>.`);
    S.pick=null; flash(id); sfx.hit(); render();
  } else if(pk.mode==='ponte1'){
    if(S.terr[id].o!==p.i||armies(id)<2) return;
    S.pick={mode:'ponte2',idx:pk.idx,src:id}; setHint('<b>Ponte aérea:</b> clique no território de destino.');
  } else if(pk.mode==='ponte2'){
    if(S.terr[id].o!==p.i||id===pk.src) return;
    const src=pk.src, idx=pk.idx, max=Math.min(5,armies(src)-1);
    S.pick=null;
    askMove('Ponte aérea',`${byId[src].n} → ${byId[id].n}`,1,max,n=>{
      S.terr[src].a-=n; S.terr[id].a+=n;
      p.powers.splice(idx,1); log(p,`transportou <em>${n}</em> exército(s) por ponte aérea até ${byId[id].n}.`);
      sfx.place(); render();
    });
  }
}

