function beginTurn(p){
  S.phase='reforco'; S.sel=null; S.pick=null; S.conquered=0; S.placed={};
  S.srcUsed=new Set(); S.gotArmies=new Set();
  p.eff.wall=false; p.eff.blitz=false; p.eff.artilharia=false;
