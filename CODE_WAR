function zoomAt(cx,cy,factor){
  const k2=clamp(view.k*factor,.7,3.4);
  const f=k2/view.k;
  view.x = cx-(cx-view.x)*f; view.y = cy-(cy-view.y)*f; view.k=k2;
  applyView();
}
function svgPt(ev){
  const r=svg.getBoundingClientRect();
  const x=( (ev.clientX-r.left)/r.width )*1600;
  const y=( (ev.clientY-r.top )/r.height)*900;
  return [x,y];
}
let mapBound=false;
function bindMap(){
  if(mapBound) return;
  mapBound=true;
  let drag=null, moved=0, downId=null;
  svg.addEventListener('wheel',e=>{e.preventDefault();const[cx,cy]=svgPt(e);zoomAt(cx,cy,e.deltaY<0?1.14:1/1.14);},{passive:false});
  svg.addEventListener('pointerdown',e=>{
    if(e.button!==0 && e.pointerType==='mouse') return;
    const g0=e.target.closest?.('.terr'); downId = g0 ? g0.dataset.id : null;
    drag={x:e.clientX,y:e.clientY,vx:view.x,vy:view.y}; moved=0; svg.classList.add('dragging'); svg.setPointerCapture(e.pointerId);
  });
  svg.addEventListener('pointermove',e=>{
    if(drag){
      const r=svg.getBoundingClientRect(), sx=1600/r.width, sy=900/r.height;
      const dx=(e.clientX-drag.x)*sx, dy=(e.clientY-drag.y)*sy;
      moved=Math.max(moved,Math.abs(dx)+Math.abs(dy));
      view.x=drag.vx+dx; view.y=drag.vy+dy; applyView();
    } else hoverTerr(e);
  });
  const up=e=>{
    if(drag){
      svg.classList.remove('dragging');
      if(moved<6 && downId){ const g=gTerr.querySelector(`[data-id="${downId}"]`); if(g) onTerrClick(downId); }
      drag=null; downId=null;
    }
  };
  svg.addEventListener('pointerup',up);
  svg.addEventListener('pointercancel',()=>{drag=null;downId=null;svg.classList.remove('dragging');});
  svg.addEventListener('pointerleave',()=>{ if(!drag) hideTip(); });
  svg.addEventListener('contextmenu',e=>{
    const g=e.target.closest?.('.terr'); if(!g) return;
    e.preventDefault();
    onTerrRightClick(g.dataset.id);
  });
  $('#zIn').onclick=()=>zoomAt(800,450,1.2);
  $('#zOut').onclick=()=>zoomAt(800,450,1/1.2);
  $('#zRst').onclick=()=>{view={k:1,x:0,y:0};applyView();};
}
