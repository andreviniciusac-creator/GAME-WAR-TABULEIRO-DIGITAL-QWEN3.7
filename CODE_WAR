function drawBattle(rolls){
  const {from,to,a,d}=B;
  const A=armies(from), D=armies(to);
  const mods=battleMods(a,d);
  $('#sideA').innerHTML=`<div class="who">Atacante · dados vermelhos</div><div class="terr-nm" style="color:${a.color.hex}">${byId[from].n}</div>
