<tr><td>Oceania</td><td>4</td><td>+2</td><td>1 (Sumatra)</td></tr>
<tr><td>América do Sul</td><td>4</td><td>+2</td><td>2 (Brasil, Venezuela)</td></tr>
<tr><td>África</td><td>6</td><td>+3</td><td>3 (Argélia, Egito)</td></tr>
<tr><td>Europa</td><td>7</td><td>+5</td><td>4 (Islândia, Polônia, França, Moscou)</td></tr>
