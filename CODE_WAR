function saveGame(){
  if(S.busy||cur().isAI){ logSys('Só é possível salvar durante o seu turno.'); return; }
  const data={...S, srcUsed:[...S.srcUsed], gotArmies:[...S.gotArmies], sel:null, pick:null, busy:false};
  const blob=new Blob([JSON.stringify(data)],{type:'application/json'});
  const a=document.createElement('a');
  a.href=URL.createObjectURL(blob); a.download='war-partida.json'; a.click();
  setTimeout(()=>URL.revokeObjectURL(a.href),2000);
}
function loadGame(txt){
  try{
    const d=JSON.parse(txt);
    Object.keys(d).forEach(k=>S[k]=d[k]);
    S.srcUsed=new Set(d.srcUsed||[]); S.gotArmies=new Set(d.gotArmies||[]);
    S.busy=false; S.sel=null; S.pick=null;
    buildMap(); renderLog(); render();
    syncOptionInputs();
    logSys('Partida carregada.');
  }catch(e){ logSys('Arquivo de partida inválido.'); }
}

