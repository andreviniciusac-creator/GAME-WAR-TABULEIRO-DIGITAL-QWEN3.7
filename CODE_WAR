function onTerrClick(id){
  if(S.gameOver||S.busy) return;
  const p=cur(); if(p.isAI) return;
  const st=S.terr[id];
  
  if(S.phase==='reforco'){
    if(S.mustTrade){ shake('#btnTrade'); return; }
    if(st.o!==p.i || S.reinf<=0) return;
    st.a++; S.reinf--; S.placed[id]=(S.placed[id]||0)+1; sfx.place(); flash(id); render();
  }
  else if(S.phase==='ataque'){
    // Se nenhum território está selecionado
    if(!S.sel){
      // Verifica se é um território do jogador com 2+ exércitos e inimigos adjacentes
      if(st.o===p.i && st.a>=2 && enemiesOf(id,p).length>0){
        S.sel=id; 
        sfx.click(); 
        render();
        setHint(`Selecionado: <b>${byId[id].n}</b> com ${st.a} exércitos. Agora clique em um território inimigo adjacente (vermelho).`);
      } else if(st.o===p.i && st.a<2){
        setHint(`Território tem apenas ${st.a} exército(s). Precisa de pelo menos 2 para atacar.`);
      } else if(st.o===p.i && enemiesOf(id,p).length===0){
        setHint(`Território não tem fronteiras com inimigos.`);
      }
      return;
    }
    
    // Se clicou no mesmo território, desseleciona
    if(id===S.sel){ 
      S.sel=null; 
      render(); 
      return; 
    }
    
    // Se clicou em outro território do jogador
    if(st.o===p.i){
      // Permite trocar a seleção se o novo território também pode atacar
      if(st.a>=2 && enemiesOf(id,p).length>0){
        S.sel=id; 
        sfx.click(); 
        render();
        setHint(`Selecionado: <b>${byId[id].n}</b> com ${st.a} exércitos.`);
      }
      return;
    }
    
    // Se clicou em território inimigo
    // Verifica se é adjacente ao território selecionado
    if(ADJ[S.sel].includes(id)){
      // Verifica trégua
      if(p.eff.cannotAttack===st.o){
        setHint('Trégua em vigor: você não pode atacar '+S.players[st.o].name+' neste turno.');
        return;
      }
      // Abre batalha
      openBattle(S.sel,id);
    } else {
      setHint(`Território <b>${byId[id].n}</b> não é adjacente a <b>${byId[S.sel].n}</b>.`);
    }
  }
  else if(S.phase==='remanejar'){
    if(!S.sel){
      if(st.o!==p.i||st.a<2||S.srcUsed.has(id)||S.gotArmies.has(id)) return;
      if(!ADJ[id].some(x=>isMine(x,p))) return;
      S.sel=id; sfx.click(); render();
    } else if(id===S.sel){ S.sel=null; render(); }
    else if(st.o===p.i && ADJ[S.sel].includes(id)){
      askMove('Deslocar exércitos', `${byId[S.sel].n} → ${byId[id].n}`, 1, armies(S.sel)-1, n=>{
        S.terr[S.sel].a-=n; st.a+=n; S.srcUsed.add(S.sel); S.gotArmies.add(id);
        log(p, `remanejou <em>${n}</em> exército(s) de ${byId[S.sel].n} para ${byId[id].n}.`);
        S.sel=null; sfx.place(); render();
      });
    } else if(st.o===p.i && armies(id)>=2 && !S.srcUsed.has(id) && !S.gotArmies.has(id)){ S.sel=id; render(); }
  }
}
