const _round=new Map();
function roundProbs(a,d){
  const key=a+':'+d;if(_round.has(key))return _round.get(key);
  const keep=Math.min(3,a),cmp=Math.min(keep,d);
  const res=new Array(cmp+1).fill(0);const A=[],D=[];
  const enumDice=(n,acc,cb)=>{if(acc.length===n){cb(acc);return;}for(let v=1;v<=6;v++){acc.push(v);enumDice(n,acc,cb);acc.pop();}};
  enumDice(a,[],r=>A.push([...r].sort((x,y)=>y-x).slice(0,3)));
  enumDice(d,[],r=>D.push([...r].sort((x,y)=>y-x)));
  const tot=A.length*D.length;
  for(const ar of A)for(const dr of D){let loss=0;for(let i=0;i<cmp;i++)if(ar[i]<=dr[i])loss++;res[loss]++;}
  for(let i=0;i<res.length;i++)res[i]/=tot;
  _round.set(key,res);return res;
}
const _win=new Map();
function pConquer(A,D){
  if(D<=0)return 1;if(A<=1)return 0;if(A>60)A=60;if(D>60)D=60;
  const key=A+'x'+D;if(_win.has(key))return _win.get(key);
  const a=Math.min(3,A-1),d=Math.min(2,D),cmp=Math.min(a,d);
  const pr=roundProbs(a,d);let p=0;
  for(let i=0;i<=cmp;i++)if(pr[i]>0)p+=pr[i]*pConquer(A-i,D-(cmp-i));
  _win.set(key,p);return p;
}
function rollDice(n){return Array.from({length:n},()=>1+rnd(6));}
function resolveRound(A,D,mods={}){
  const an=Math.min(mods.extraDie?4:3,A-1);
  const dn=Math.min(2,D);
  const aRaw=rollDice(an).sort((x,y)=>y-x);const aKept=aRaw.slice(0,3);
  const dRaw=rollDice(dn).sort((x,y)=>y-x);const dEff=[...dRaw];
  if(mods.wall&&dEff.length)dEff[0]=Math.min(7,dEff[0]+1);
  const cmp=Math.min(aKept.length,dEff.length);
  let aLoss=0,dLoss=0;const pairs=[];
  for(let i=0;i<cmp;i++){if(aKept[i]>dEff[i]){dLoss++;pairs.push('a');}else{aLoss++;pairs.push('d');}}
  return{aRaw,aKept,dRaw,dEff,aLoss,dLoss,pairs,cmp};
}
function buildDeck(){const d=TERRS.map(t=>({t:t.id,s:t.s}));d.push({t:null,s:'W'},{t:null,s:'W'});return shuffle(d);}
function drawCard(){if(!S.deck.length){S.deck=shuffle(S.discard.splice(0));}return S.deck.pop()||null;}
function drawPower(){if(!S.powerDeck.length)S.powerDeck=shuffle(POWERS.map(p=>p.id).concat(POWERS.map(p=>p.id)));return S.powerDeck.pop();}
function tradeValue(n){const t=[4,6,8,10,12,15];return n<=6?t[n-1]:15+5*(n-6);}
function isSet(cards){
  if(cards.length!==3)return false;
  const w=cards.filter(c=>c.s==='W').length;
  const s=cards.filter(c=>c.s!=='W').map(c=>c.s);
  if(w>=2)return true;const u=new Set(s);
  if(w===1)return u.size===1||u.size===2;
  return u.size===1||u.size===3;
}
function findSet(cards){
  for(let i=0;i<cards.length;i++)for(let j=i+1;j<cards.length;j++)for(let k=j+1;k<cards.length;k++){
    const c=[cards[i],cards[j],cards[k]];if(isSet(c))return c;
  }return null;
}
