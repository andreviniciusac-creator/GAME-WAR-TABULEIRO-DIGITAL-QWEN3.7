<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="WAR">
<meta name="mobile-web-app-capable" content="yes">
<meta name="theme-color" content="#05090f">
<title>WAR — Estratégia e Conquista</title>
<style>
:root{
  --abyss:#05090f;--ink:#0b1322;--chart:#132039;--panel:rgba(12,20,34,.82);
  --line:rgba(200,155,60,.18);--line2:rgba(148,170,200,.14);--brass:#c89b3c;
  --brass-dim:#8a6c2c;--verdigris:#4e9c8b;--rust:#b5442e;--bone:#e6e2d3;
  --muted:#8fa0b8;--shadow:0 18px 50px -20px rgba(0,0,0,.9);
  --serif:"Iowan Old Style","Palatino Linotype",Palatino,"Book Antiqua",Georgia,serif;
  --sans:-apple-system,BlinkMacSystemFont,"SF Pro Text","Helvetica Neue",system-ui,Roboto,"Segoe UI",Arial,sans-serif;
  --mono:ui-monospace,SFMono-Regular,"SF Mono",Menlo,Consolas,monospace;
  --sat: env(safe-area-inset-top, 0px);
  --sab: env(safe-area-inset-bottom, 0px);
  --sal: env(safe-area-inset-left, 0px);
  --sar: env(safe-area-inset-right, 0px);
}
*{box-sizing:border-box;-webkit-tap-highlight-color:transparent}
html,body{
  height:100%;height:100vh;height:100dvh;
  margin:0;padding:0;
  background:var(--abyss);color:var(--bone);
  font-family:var(--sans);
  -webkit-font-smoothing:antialiased;
  -webkit-text-size-adjust:100%;
  text-size-adjust:100%;
  overflow:hidden;
  position:fixed;
  width:100%;
  /* ✅ CORREÇÃO: touch-action APENAS no mapa, não no body */
  -webkit-touch-callout:none;
  -webkit-user-select:none;
  user-select:none;
  overscroll-behavior:none;
}
/* ✅ CORREÇÃO: Permitir interação em inputs */
input,select,textarea{
  -webkit-user-select:text;
  user-select:text;
  -webkit-touch-callout:default;
}
button{
  font:inherit;color:inherit;cursor:pointer;
  min-height:44px;min-width:44px;
  -webkit-appearance:none;appearance:none;
  border:none;background:none;
}
input,select{
  -webkit-appearance:none;appearance:none;
  font-size:16px;
  min-height:44px;
}
#app{
  display:grid;
  grid-template-rows:auto 1fr auto;
  height:100vh;height:100dvh;
  gap:0;
  padding-top:var(--sat);
  padding-bottom:var(--sab);
  padding-left:var(--sal);
  padding-right:var(--sar);
}
.topbar{
  display:flex;align-items:center;gap:10px;
  padding:8px 12px;padding-left:calc(12px + var(--sal));padding-right:calc(12px + var(--sar));
  border-bottom:1px solid var(--line);
  background:linear-gradient(180deg,rgba(19,32,57,.95),rgba(5,9,15,.85));
  -webkit-backdrop-filter:blur(12px);backdrop-filter:blur(12px);
  flex-wrap:wrap;
}
.brand{display:flex;align-items:baseline;gap:8px;flex:0 0 auto}
.brand b{font-family:var(--serif);font-size:20px;letter-spacing:.3em;font-weight:600;color:var(--brass);text-shadow:0 0 22px rgba(200,155,60,.35)}
.brand span{font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);display:none}
.turnbox{display:flex;align-items:center;gap:7px;padding:4px 10px;border:1px solid var(--line);border-radius:999px;background:rgba(0,0,0,.28)}
.turnbox .dot{width:11px;height:11px;border-radius:50%;box-shadow:0 0 0 2px rgba(0,0,0,.5),0 0 12px currentColor}
.turnbox b{font-size:12px;letter-spacing:.04em}
.turnbox small{font-size:10px;color:var(--muted);font-family:var(--mono)}
.phases{display:flex;align-items:center;gap:0;margin-left:auto}
.phase{font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);padding:6px 10px;border:1px solid transparent;position:relative;white-space:nowrap;min-height:36px;display:flex;align-items:center}
.phase.active{color:var(--abyss);background:var(--brass);border-radius:4px;font-weight:700;box-shadow:0 0 14px -4px var(--brass)}
.tools{display:flex;gap:4px;flex:0 0 auto;flex-wrap:wrap}
.btn{
  background:rgba(255,255,255,.03);border:1px solid var(--line2);color:var(--bone);
  padding:8px 12px;border-radius:7px;font-size:12.5px;letter-spacing:.02em;
  transition:.16s border-color,.16s background;
  min-height:44px;
  -webkit-backdrop-filter:blur(6px);backdrop-filter:blur(6px);
}
.btn:active{background:rgba(200,155,60,.15);transform:scale(.98)}
.btn:disabled{opacity:.32;cursor:not-allowed}
.btn.primary{background:var(--brass);color:#1a1206;border-color:var(--brass);font-weight:700}
.btn.primary:active{background:#dcae4c}
.btn.good{background:rgba(78,156,139,.2);border-color:rgba(78,156,139,.5);color:#9fe0cf}
.btn.bad{background:rgba(181,68,46,.18);border-color:rgba(181,68,46,.5);color:#f0a795}
.btn.sm{padding:6px 10px;font-size:11.5px;border-radius:6px;min-height:36px}
.btn.icon{padding:8px 10px}
select,input[type=text]{
  background:rgba(0,0,0,.35);border:1px solid var(--line2);color:var(--bone);
  padding:8px 10px;border-radius:7px;font:inherit;font-size:16px;min-height:44px;
}
label.chk{display:flex;align-items:center;gap:9px;font-size:13px;cursor:pointer;padding:8px 0;color:var(--bone);min-height:44px}
label.chk input{accent-color:var(--brass);width:20px;height:20px}
.stage{display:grid;grid-template-columns:262px minmax(0,1fr) 306px;gap:10px;padding:10px;min-height:0;overflow:hidden}
.col{display:flex;flex-direction:column;gap:10px;min-height:0;overflow:auto;padding-right:2px;-webkit-overflow-scrolling:touch}
.panel{background:var(--panel);border:1px solid var(--line2);border-radius:12px;-webkit-backdrop-filter:blur(9px);backdrop-filter:blur(9px);box-shadow:var(--shadow);overflow:hidden;flex:0 0 auto}
.panel>h3{margin:0;padding:10px 12px;font-family:var(--serif);font-size:11px;font-weight:600;letter-spacing:.22em;text-transform:uppercase;color:var(--brass);border-bottom:1px solid var(--line);display:flex;align-items:center;justify-content:space-between;gap:8px}
.panel>h3 .tag{font-family:var(--mono);letter-spacing:0;font-size:10px;color:var(--muted);text-transform:none}
.panel .body{padding:10px 12px}
.panel.grow{flex:1 1 auto;display:flex;flex-direction:column;min-height:120px}
.panel.grow .body{overflow:auto;-webkit-overflow-scrolling:touch;flex:1 1 auto}
.prow{display:grid;grid-template-columns:14px 1fr auto;gap:8px;align-items:center;padding:8px 0;border-bottom:1px dashed rgba(148,170,200,.1);min-height:44px}
.prow:last-child{border-bottom:0}
.prow .dot{width:13px;height:13px;border-radius:3px;box-shadow:0 0 0 1px rgba(0,0,0,.6)}
.prow .nm{font-size:13px;line-height:1.25}
.prow .nm small{display:block;font-size:10px;color:var(--muted);letter-spacing:.06em;text-transform:uppercase}
.prow .st{font-family:var(--mono);font-size:11px;color:var(--muted);text-align:right;white-space:nowrap}
.prow.active{background:linear-gradient(90deg,rgba(200,155,60,.12),transparent);margin:0 -12px;padding-left:12px;padding-right:12px;border-radius:6px}
.prow.dead{opacity:.34;filter:grayscale(1)}
.bar{height:3px;border-radius:2px;background:rgba(255,255,255,.07);margin-top:5px;overflow:hidden;grid-column:2/4}
.bar i{display:block;height:100%;border-radius:2px;transition:width .5s cubic-bezier(.2,.8,.2,1)}
.crow{display:flex;align-items:center;gap:8px;padding:6px 0;font-size:12.5px;min-height:36px}
.crow .swatch{width:9px;height:9px;border-radius:2px;flex:0 0 auto}
.crow .nm{flex:1 1 auto}
.crow .bonus{font-family:var(--mono);font-size:11px;color:var(--brass)}
.crow .own{font-family:var(--mono);font-size:11px;color:var(--muted)}
.crow.complete .nm{color:#fff;font-weight:600}
/* ✅ CORREÇÃO CRÍTICA: touch-action APENAS no mapa */
.mapwrap{
  position:relative;border-radius:14px;overflow:hidden;border:1px solid var(--line2);
  background:radial-gradient(120% 100% at 50% 0%,#16273f 0%,#0a1120 48%,#04070d 100%);
  box-shadow:var(--shadow);min-height:0;
  touch-action:none;
  -webkit-touch-callout:none;
}
#map{display:block;width:100%;height:100%;touch-action:none;cursor:grab;-webkit-user-select:none;user-select:none}
#map.dragging{cursor:grabbing}
.zoomctl{position:absolute;right:10px;bottom:10px;display:flex;flex-direction:column;gap:5px;z-index:5}
.zoomctl .btn{padding:8px 10px;background:rgba(6,10,18,.85);min-height:44px;min-width:44px;font-size:18px}
.maphint{position:absolute;left:12px;top:10px;font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:rgba(230,226,211,.5);pointer-events:none;background:rgba(0,0,0,.4);padding:6px 10px;border-radius:6px;-webkit-backdrop-filter:blur(6px);backdrop-filter:blur(6px);animation:fadeout .9s ease 7s forwards}
@keyframes fadeout{to{opacity:0}}
.tp{stroke:rgba(4,8,14,.85);stroke-width:1.6;stroke-linejoin:round;stroke-linecap:round;transition:fill .35s ease,opacity .2s}
.tn{font-family:var(--sans);font-size:12px;letter-spacing:.04em;fill:rgba(238,242,250,.75);text-anchor:middle;pointer-events:none;paint-order:stroke;stroke:rgba(3,6,12,.9);stroke-width:3px}
.terr{cursor:pointer}
.terr .tp{filter:saturate(1.05)}
.terr:hover .tp,.terr:active .tp{stroke:#fff;stroke-width:2.4}
.terr.sel .tp{stroke:var(--brass);stroke-width:3.4;filter:drop-shadow(0 0 12px rgba(200,155,60,.85))}
.terr.tgt .tp{stroke:var(--rust);stroke-width:3;filter:drop-shadow(0 0 10px rgba(181,68,46,.8))}
.terr.dim{opacity:.34}
.terr.pulse .tp{animation:pulse 1.5s ease-in-out infinite}
@keyframes pulse{0%,100%{stroke-opacity:.55}50%{stroke-opacity:1}}
.badge circle{stroke:rgba(3,7,14,.9);stroke-width:1.6}
.badge text{font-family:var(--mono);font-size:14px;font-weight:700;text-anchor:middle;dominant-baseline:central;pointer-events:none}
.link{stroke:rgba(160,190,220,.16);stroke-width:1.3;fill:none}
.link.sea{stroke:rgba(200,155,60,.26);stroke-dasharray:5 6}
.clabel{font-family:var(--serif);font-size:14px;letter-spacing:.3em;text-transform:uppercase;text-anchor:middle;pointer-events:none;opacity:.5}
.cbonus{font-family:var(--mono);font-size:11px;letter-spacing:.1em;text-anchor:middle;pointer-events:none;opacity:.42}
.ripple{fill:none;stroke-width:3;pointer-events:none}
#tooltip{position:absolute;pointer-events:none;z-index:20;opacity:0;transform:translateY(4px);transition:opacity .12s,transform .12s;background:rgba(6,11,20,.95);border:1px solid var(--line);border-radius:9px;padding:8px 11px;font-size:12px;min-width:150px;box-shadow:var(--shadow);-webkit-backdrop-filter:blur(10px);backdrop-filter:blur(10px);max-width:260px}
#tooltip.on{opacity:1;transform:none}
#tooltip b{display:block;font-family:var(--serif);letter-spacing:.1em;text-transform:uppercase;font-size:11.5px;color:var(--brass);margin-bottom:3px}
#tooltip .r{display:flex;justify-content:space-between;gap:12px;color:var(--muted);font-size:11px;line-height:1.7}
#tooltip .r i{font-style:normal;color:var(--bone);font-family:var(--mono)}
.obj{font-size:13px;line-height:1.55;color:var(--bone)}
.hand{display:flex;flex-wrap:wrap;gap:6px}
.tcard{width:64px;border:1px solid var(--line2);border-radius:8px;padding:6px 5px;text-align:center;background:linear-gradient(160deg,rgba(255,255,255,.05),rgba(0,0,0,.25));cursor:pointer;transition:.15s;min-height:70px}
.tcard:active{transform:scale(.95)}
.tcard.on{border-color:var(--brass);background:rgba(200,155,60,.16);box-shadow:0 0 14px -3px var(--brass)}
.tcard .sym{font-size:18px;line-height:1;color:var(--brass)}
.tcard .nm{font-size:8.5px;letter-spacing:.04em;text-transform:uppercase;color:var(--muted);margin-top:5px;line-height:1.25;height:22px;overflow:hidden}
.tcard.mine .nm{color:var(--verdigris)}
.power{display:flex;gap:9px;align-items:flex-start;padding:8px;border:1px solid var(--line2);border-radius:9px;margin-bottom:7px;background:rgba(255,255,255,.025)}
.power .ico{font-size:18px;line-height:1.1}
.power .t{font-size:12px;font-weight:600;letter-spacing:.02em}
.power .d{font-size:10.5px;color:var(--muted);line-height:1.45;margin-top:2px}
.log{font-size:11.5px;line-height:1.5}
.logline{display:flex;gap:7px;padding:4px 0;border-bottom:1px dashed rgba(148,170,200,.08)}
.logline .d{width:7px;height:7px;border-radius:50%;margin-top:5px;flex:0 0 auto}
.logline em{font-style:normal;color:var(--brass)}
.logline.sys{color:var(--muted)}
.bottombar{display:flex;align-items:center;gap:10px;padding:8px 12px;padding-left:calc(12px + var(--sal));padding-right:calc(12px + var(--sar));border-top:1px solid var(--line);background:linear-gradient(0deg,rgba(19,32,57,.95),rgba(5,9,15,.85));-webkit-backdrop-filter:blur(12px);backdrop-filter:blur(12px);flex-wrap:wrap}
#hint{font-size:12px;color:var(--muted);flex:1 1 auto;min-width:0}
#hint b{color:var(--bone);font-weight:600}
.reinf{display:flex;align-items:center;gap:8px;padding:6px 12px;border-radius:999px;border:1px solid var(--line);background:rgba(200,155,60,.1);font-size:12px;min-height:36px}
.reinf b{font-family:var(--mono);font-size:18px;color:var(--brass);line-height:1}
.actions{display:flex;gap:6px;flex-wrap:wrap;justify-content:flex-end}
.backdrop{position:fixed;inset:0;background:rgba(3,6,12,.85);-webkit-backdrop-filter:blur(8px);backdrop-filter:blur(8px);display:none;align-items:center;justify-content:center;z-index:50;padding:16px;padding-top:calc(16px + var(--sat));padding-bottom:calc(16px + var(--sab));overflow-y:auto;-webkit-overflow-scrolling:touch}
.backdrop.on{display:flex}
.modal{width:min(680px,100%);max-height:85vh;overflow:auto;background:linear-gradient(180deg,#101b2f,#080d18);border:1px solid var(--line);border-radius:16px;box-shadow:0 40px 90px -30px #000;animation:rise .28s cubic-bezier(.2,.9,.2,1);-webkit-overflow-scrolling:touch}
.modal.wide{width:min(880px,100%)}
.modal.slim{width:min(460px,100%)}
@keyframes rise{from{opacity:0;transform:translateY(16px) scale(.98)}}
.modal header{padding:16px 20px 12px;border-bottom:1px solid var(--line);position:sticky;top:0;background:linear-gradient(180deg,#101b2f,#0d1524);z-index:2}
.modal header h2{margin:0;font-family:var(--serif);font-size:18px;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:var(--brass)}
.modal header p{margin:5px 0 0;font-size:12px;color:var(--muted);line-height:1.55}
.modal .content{padding:16px 20px}
.modal footer{padding:12px 20px 16px;display:flex;gap:8px;justify-content:flex-end;flex-wrap:wrap;position:sticky;bottom:0;background:linear-gradient(0deg,#080d18,#0d1524);border-top:1px solid var(--line)}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.field{display:flex;flex-direction:column;gap:6px;margin-bottom:12px}
.field>span{font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:var(--muted)}
/* ✅ CORREÇÃO: Swatches com role=button e estilos adequados */
.swatches{display:flex;gap:10px;flex-wrap:wrap}
.sw{
  width:48px;height:48px;border-radius:10px;
  border:3px solid transparent;
  cursor:pointer;transition:.15s;
  /* ✅ Essencial para iOS reconhecer como clicável */
  -webkit-tap-highlight-color:rgba(200,155,60,.3);
  touch-action:manipulation;
}
.sw.on{border-color:var(--brass);transform:scale(1.1);box-shadow:0 0 20px -3px var(--brass)}
.sw:active{transform:scale(.92);opacity:.85}
.duel{display:grid;grid-template-columns:1fr 64px 1fr;gap:10px;align-items:center}
.side{text-align:center;padding:12px;border-radius:12px;border:1px solid var(--line2);background:rgba(0,0,0,.25)}
.side .who{font-size:10px;letter-spacing:.18em;text-transform:uppercase;color:var(--muted)}
.side .terr-nm{font-family:var(--serif);font-size:15px;letter-spacing:.08em;margin:3px 0 2px}
.side .armies{font-family:var(--mono);font-size:12px;color:var(--muted)}
.side .armies b{color:var(--bone);font-size:18px}
.vs{text-align:center;font-family:var(--serif);letter-spacing:.14em;color:var(--brass);font-size:14px}
.odds{font-family:var(--mono);font-size:11.5px;color:var(--muted);text-align:center;margin-top:9px}
.odds b{color:var(--brass);font-size:14px}
.oddsbar{height:5px;border-radius:3px;background:rgba(181,68,46,.4);overflow:hidden;margin-top:6px}
.oddsbar i{display:block;height:100%;background:var(--verdigris);transition:width .4s}
.dicerow{display:flex;gap:6px;justify-content:center;margin-top:10px;min-height:44px;flex-wrap:wrap}
.die{width:38px;height:38px;border-radius:9px;display:grid;grid-template:repeat(3,1fr)/repeat(3,1fr);padding:5px;background:linear-gradient(150deg,#c94a36,#7c2318);box-shadow:0 5px 12px -4px #000,inset 0 -2px 0 rgba(0,0,0,.28),inset 0 1px 0 rgba(255,255,255,.18);border:1px solid rgba(0,0,0,.35)}
.die.def{background:linear-gradient(150deg,#e0b13e,#a97a12)}
.die .pip{width:6px;height:6px;border-radius:50%;background:#f5efe4;align-self:center;justify-self:center;box-shadow:inset 0 1px 1px rgba(0,0,0,.4)}
.die.def .pip{background:#2a1d08}
.die.faded{opacity:.32}
.die.win{outline:2px solid var(--verdigris);outline-offset:2px}
.die.lose{outline:2px solid #050505;outline-offset:2px;opacity:.6;filter:saturate(.4)}
.die.rolling{animation:tumble .55s cubic-bezier(.36,.07,.19,.97) infinite}
.die.settle{animation:settle .32s ease-out}
@keyframes tumble{0%{transform:translateY(0) rotate(0) scale(1)}20%{transform:translateY(-10px) rotate(-95deg) scale(1.06)}45%{transform:translateY(2px) rotate(160deg) scale(.96)}70%{transform:translateY(-6px) rotate(280deg) scale(1.04)}100%{transform:translateY(0) rotate(360deg) scale(1)}}
@keyframes settle{0%{transform:scale(1.35);filter:brightness(1.6)}60%{transform:scale(.94)}100%{transform:scale(1);filter:brightness(1)}}
.roundtag{font-family:var(--mono);font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);text-align:center;margin-top:10px}
.blog{margin-top:12px;max-height:132px;overflow:auto;-webkit-overflow-scrolling:touch;font-family:var(--mono);font-size:11px;color:var(--muted);line-height:1.7;border-top:1px solid var(--line2);padding-top:8px}
.blog .win{color:var(--verdigris)}
.blog .lose{color:#f0a795}
.stat{display:flex;align-items:center;gap:9px;margin-bottom:9px}
.stat .nm{width:104px;font-size:12px}
.stat .track{flex:1;height:16px;background:rgba(255,255,255,.05);border-radius:4px;overflow:hidden;display:flex}
.stat .track i{display:block;height:100%}
.stat .v{font-family:var(--mono);font-size:11.5px;color:var(--muted);width:78px;text-align:right}
.victory-sub{font-family:var(--serif);font-size:14px;letter-spacing:.08em;color:var(--bone);text-align:center;line-height:1.7}
.crown{font-size:48px;text-align:center;margin:6px 0 2px}
.tabs{display:none;gap:6px;padding:6px 10px;background:rgba(0,0,0,.3)}
.tabs .btn{flex:1;min-height:40px}
@media (max-width:1180px){
  .stage{grid-template-columns:1fr;grid-template-rows:minmax(0,1fr)}
  .col{display:none;max-height:40vh}
  .col.show{display:flex}
  .tabs{display:flex}
  .brand span{display:none}
  .phase{padding:6px 8px;font-size:9px;letter-spacing:.09em}
}
@media (max-width:720px){
  .topbar{padding:6px 10px;gap:6px}
  .brand b{font-size:17px;letter-spacing:.22em}
  .turnbox{padding:4px 8px}
  .turnbox b{font-size:11px}
  .turnbox small{font-size:9px}
  .phase{padding:5px 6px;font-size:8.5px}
  .tools{gap:3px}
  .btn{padding:7px 10px;font-size:11.5px;min-height:40px}
  .bottombar{padding:6px 10px;gap:6px}
  #hint{font-size:11px;width:100%}
  .actions{width:100%;justify-content:stretch}
  .actions .btn{flex:1}
  .duel{grid-template-columns:1fr;gap:8px}
  .vs{padding:2px}
  .modal{max-height:90vh}
  .modal header h2{font-size:16px}
  .grid2{grid-template-columns:1fr}
  .panel>h3{font-size:10px;padding:8px 10px}
  .panel .body{padding:8px 10px}
  .tcard{width:58px;min-height:64px}
  .tcard .sym{font-size:16px}
  .tcard .nm{font-size:8px}
  .die{width:34px;height:34px}
