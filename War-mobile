function baseReinf(p){const t=ownedBy(p).length;let n=Math.floor(t/2);n=S.settings.min3?Math.max(3,n):Math.max(1,n);return n;}
function contBonus(p){let b=0,list=[];Object.keys(CONTS).forEach(c=>{if(contOwned(p,c)){b+=CONTS[c].bonus;list.push(c);}});return{b,list};}
function computeReinf(p){const{b}=contBonus(p);return baseReinf(p)+b;}
function objectiveDone(p){
  const o=p.obj;if(!o)return false;const owned=ownedBy(p);
  if(owned.length===42)return true;
  if(o.type==='total')return owned.length===42;
  if(o.type==='cont'){if(!o.conts.every(c=>contOwned(p,c)))return false;if(!o.extra)return true;const others=Object.keys(CONTS).filter(c=>!o.conts.includes(c)).filter(c=>contOwned(p,c));return others.length>=o.extra;}
  if(o.type==='terr'){if(o.min>1)return owned.filter(id=>armies(id)>=o.min).length>=o.count;return owned.length>=o.count;}
  if(o.type==='destroy'){const tgt=S.players.find(x=>x.color.id===o.color);if(!tgt||tgt.i===p.i)return owned.length>=24;if(tgt.alive)return false;if(tgt.killedBy===p.i)return true;return owned.length>=24;}
  return false;
}
function objectiveText(p){
  const o=p.obj;if(!o)return'';
  if(o.type!=='destroy')return o.txt;
  const tgt=S.players.find(x=>x.color.id===o.color);
  if(!tgt||tgt.i===p.i)return'Conquistar 24 territórios. (alvo fora do jogo)';
  if(!tgt.alive&&tgt.killedBy!==p.i)return'Conquistar 24 territórios. (alvo eliminado por outro)';
  return o.txt;
}
function checkVictory(){
  if(S.gameOver)return false;
  const alive=S.players.filter(p=>p.alive);
  if(alive.length===1){endGame(alive[0],'Último exército.');return true;}
  for(const p of S.players){if(!p.alive)continue;if(objectiveDone(p)){endGame(p,ownedBy(p).length===42?'Conquista total.':'Objetivo cumprido.');return true;}}
  return false;
}
function eliminate(victim,killer){
  victim.alive=false;victim.killedBy=killer.i;killer.kills++;
  const stolen=victim.cards.splice(0);killer.cards.push(...stolen);
